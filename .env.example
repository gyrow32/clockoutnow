# Website environment variables (example)
# Copy to `website/.env.local` and fill in values.

# Public (safe to expose in the browser bundle)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Admin dashboard access (server-checked)
ADMIN_ACCESS_KEY=change-me

# Optional (used by Python scripts for image generation)
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
