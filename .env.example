# ClockOutNow environment variables (example)
# Copy to `.env.local` and fill in values. Never commit `.env.local`.

# Supabase (used by Python scripts)
SUPABASE_URL=https://YOUR-PROJECT-ID.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# Base origin for preview links (optional)
BASE_URL=http://localhost:3000

# Optional: Gmail sending (only needed if/when you automate sending)
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=your-gmail-app-password
SEND_AS_EMAIL=hello@clockoutnow.com
SEND_AS_NAME=ClockOutNow
